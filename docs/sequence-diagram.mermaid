sequenceDiagram
    participant App as App Entry
    participant ST as SheepsTheme()
    participant TM as ThemeManager
    participant M3 as MaterialTheme
    participant TCB as TileCardBase()
    participant Canvas as Canvas DrawScope

    App->>TM: init() 从 MMKV 读取主题
    App->>ST: SheepsTheme { content }
    ST->>TM: currentTheme.collectAsState()
    TM-->>ST: AppTheme (e.g. SAKURA)
    ST->>M3: MaterialTheme(colorScheme = SakuraColorScheme)
    Note over M3: colorScheme 注入 CompositionLocal

    App->>TCB: TileCardBase(skin = "cyber")
    TCB->>M3: val cs = MaterialTheme.colorScheme
    Note over TCB: 提取 cs.surface, cs.onSurface 等到局部变量
    TCB->>TCB: when(normalizedSkin) { bgColor, borderColor, decorColor }
    TCB->>Canvas: Canvas { drawRoundRect(cs.surfaceVariant), drawLine(cs.onSurfaceVariant) }
    Note over Canvas: Canvas 内使用闭包捕获的局部变量

    rect rgb(200, 230, 255)
        Note over TCB: 皮肤差异化决策
        TCB->>TCB: ink → cs.surfaceVariant / onSurface(0.8f) / onSurfaceVariant
        TCB->>TCB: cyber → cs.surface / primary / secondary
        TCB->>TCB: keai → cs.surfaceVariant / secondary / secondary(0.7f)
        TCB->>TCB: daimeng → cs.surfaceVariant / primary(0.8f) / primary(0.5f)
        TCB->>TCB: classic → cs.surface / secondary / secondary(0.5f)
    end

    rect rgb(255, 240, 220)
        Note over App,Canvas: P1 通用替换流程
        Note over App,Canvas: Color.White/FFFFFDF9/FCFAF6 → cs.surface
        Note over App,Canvas: Color(0xFFE5DDD3) → cs.outlineVariant
        Note over App,Canvas: Color.DarkGray/333333/1C1A17 → cs.onSurface
        Note over App,Canvas: Color.Gray/888888 → cs.onSurfaceVariant
        Note over App,Canvas: Color.Black.copy(0.5f) → cs.scrim
        Note over App,Canvas: Color.White (Button text) → cs.onPrimary
    end
