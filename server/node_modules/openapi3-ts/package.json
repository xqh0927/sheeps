{
    "name": "openapi3-ts",
    "version": "4.6.0",
    "description": "TS Model & utils for OpenAPI 3.x specification.",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./oas30": {
            "types": "./dist/oas30.d.ts",
            "import": "./dist/oas30.mjs",
            "require": "./dist/oas30.js"
        },
        "./oas31": {
            "types": "./dist/oas31.d.ts",
            "import": "./dist/oas31.mjs",
            "require": "./dist/oas31.js"
        },
        "./oas32": {
            "types": "./dist/oas32.d.ts",
            "import": "./dist/oas32.mjs",
            "require": "./dist/oas32.js"
        }
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/metadevpro/openapi3-ts.git"
    },
    "scripts": {
        "clean": "rimraf dist",
        "build": "vite build && tsc --emitDeclarationOnly",
        "version": "node --version && npm --version && eslint --version && tsc --version && vite --version && vitest --version",
        "build:all": "rimraf dist && npm run lint && npm run build && npm test",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "test:tdd": "vitest -w",
        "test": "vitest",
        "test:ci": "npm run test",
        "cover": "vitest --coverage",
        "cover:ci": "npm run cover",
        "publish": "npm run build:all && npm publish ."
    },
    "keywords": [
        "openapi3",
        "ts",
        "typescript"
    ],
    "author": "Pedro J. Molina / Metadev",
    "license": "MIT",
    "dependencies": {
        "yaml": "^2.9.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@types/node": "^25.9.1",
        "@typescript-eslint/eslint-plugin": "^8.60.0",
        "@typescript-eslint/parser": "^8.60.0",
        "@vitest/coverage-v8": "^4.1.8",
        "coveralls": "^3.1.1",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "typescript": "~5.9.3",
        "vite": "^8.0.16",
        "vitest": "^4.1.8",
        "vitest-teamcity-reporter": "^0.4.1"
    },
    "files": [
        "dist",
        "*.md",
        "oas30.d.ts",
        "oas31.d.ts",
        "oas32.d.ts"
    ]
}
